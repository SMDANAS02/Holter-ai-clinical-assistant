# Holter Monitor AI Pipeline - Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env with real API keys to version control

# ============================================================================
# GROQ API (Recommended - Fastest inference)
# ============================================================================
# Get your API key from: https://console.groq.com
# Format: gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Model: openai/gpt-oss-120b (current recommended production model)
GROQ_API_KEY=your-groq-api-key-here

# ============================================================================
# SUPABASE AUTHENTICATION
# ============================================================================
# Get these from your Supabase project: https://app.supabase.com
# Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here-eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# DATABASE CONNECTION (Supabase PostgreSQL)
# ============================================================================
# Connection string for backend to write authenticated recordings
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/holter_db

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Port for Streamlit dashboard (default: 8501)
STREAMLIT_PORT=8501

# Path to findings.json file
FINDINGS_PATH=findings.json

# Pipeline configuration
PIPELINE_DAYS=7
PIPELINE_THRESHOLD=3.0

# ============================================================================
# LOGGING
# ============================================================================

# Log level: DEBUG, INFO, WARN, ERROR (default: INFO)
LOG_LEVEL=INFO

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Set to true for development mode (default: false)
DEBUG=false

# Cache TTL in seconds for dashboard data (default: 60)
CACHE_TTL=60

# ============================================================================
# JAVA SETTINGS
# ============================================================================

# Java heap size (adjust based on your system)
JAVA_OPTS=-Xmx2G

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Set up Supabase authentication:
#    a. Create project at https://app.supabase.com
#    b. Go to Project Settings > API and copy:
#       - Project URL (format: https://your-project.supabase.co) → SUPABASE_URL
#       - anon/public key (long JWT token) → SUPABASE_ANON_KEY
#    c. Set up Database authentication trigger (see Supabase docs)
#
# 3. Configure database connection:
#    a. Get PostgreSQL connection string from Supabase:
#       - Project Settings > Database > Connection string (PostgreSQL)
#    b. Format: postgresql://user:password@host:port/database
#       Example: postgresql://postgres:mypassword@db.supabase.co:5432/postgres
#    c. Copy connection string → DATABASE_URL
#    d. Ensure database is accessible from application host
#
# 4. Choose your AI provider and edit .env:
#    Option A: Groq (recommended - fastest)
#      - Get key from https://console.groq.com
#      - GROQ_API_KEY=gsk_your_actual_key_here
#    
#    Option B: Grok (via xAI)
#      - Get key from https://console.x.ai
#      - GROK_API_KEY=gsk_your_actual_key_here
#
# 5. .env will be loaded automatically by the application
#
# 6. Make sure .env is in .gitignore (never commit real keys!)
#
# 7. Verify configuration by:
#    - Starting the Streamlit dashboard: streamlit run dashboard/st_dashboard.py
#    - Checking for warning messages about missing SUPABASE_URL or SUPABASE_ANON_KEY
#    - Testing PDF upload, authentication, and database connectivity
